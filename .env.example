# =============================================================
# SHREEJI ART — ENVIRONMENT VARIABLES TEMPLATE
# Copy this to .env and fill in actual values.
# NEVER commit real secrets to version control.
# =============================================================

# ── Backend: Database (Supabase PostgreSQL) ──────────────────
# Use the "Transaction" pooler connection string from Supabase
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your-supabase-db-password

# ── Backend: JWT ─────────────────────────────────────────────
# Generate a strong 256-bit base64 secret:
#   openssl rand -base64 32
JWT_SECRET=your-256-bit-base64-encoded-secret-here
JWT_EXPIRATION_MS=86400000

# ── Backend: Server ──────────────────────────────────────────
SERVER_PORT=8080
ALLOWED_ORIGINS=http://localhost:3000,https://shreeji-art.vercel.app

# ── Frontend: API ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# ── Frontend: App ────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Shreeji Art
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (optional: for direct client use) ───────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
